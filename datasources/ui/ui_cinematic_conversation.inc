		Location='50,100'
		Name='npcViewerPage'
		ScrollExtent='200,200'
		Size='200,200'
		Visible='true'
	>
		<CuiWidget3dObjectListViewer
			cameralookatcenter='true'
			CameraPitch='0.3'
			cameratransformtoobj='true'
			camerayaw='180'
			dragpitchok='false'
